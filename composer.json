{
    "name": "amashukov/ton-cell-php",
    "description": "TLB Cell / Builder / Slice / canonical BOC encoder for The Open Network in pure PHP — byte-exact equivalent of @ton/core's cell layer.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/AndreyMashukov/ton-cell-php",
    "keywords": ["ton", "the-open-network", "tlb", "cell", "boc", "bag-of-cells", "builder", "slice", "blockchain", "pure-php"],
    "authors": [
        {
            "name": "Andrei Mashukov",
            "email": "a.mashukoff@gmail.com",
            "homepage": "https://github.com/AndreyMashukov"
        }
    ],
    "support": {
        "issues": "https://github.com/AndreyMashukov/ton-cell-php/issues",
        "source": "https://github.com/AndreyMashukov/ton-cell-php"
    },
    "require": {
        "php": ">=8.3",
        "ext-gmp": "*"
    },
    "require-dev": {
        "amashukov/rector-php-rules": "^0.1.0",
        "friendsofphp/php-cs-fixer": "^3.50",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Amashukov\\TonCell\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amashukov\\TonCell\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run"
    }
}
